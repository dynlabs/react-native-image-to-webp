# Set default behavior to automatically normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files you want to always be normalized and converted
# to native line endings on checkout.
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.properties text eol=lf
*.kt text eol=lf
*.java text eol=lf
*.swift text eol=lf
*.m text eol=lf
*.mm text eol=lf
*.h text eol=lf
*.cpp text eol=lf
*.c text eol=lf
*.hpp text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
*.cmake text eol=lf
*.am text eol=lf
*.in text eol=lf
*.txt text eol=lf
*.config text eol=lf
*.rc text eol=lf

# Windows-specific files that require CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.pbxproj -text
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.jar binary
*.keystore binary
*.mp4 binary
*.zip binary
