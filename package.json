{
  "name": "@dynlabs/react-native-image-to-webp",
  "version": "1.0.1",
  "description": "React Native TurboModule to convert JPEG and PNG images to WebP format with quality presets, resizing, and EXIF stripping — for iOS and Android",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace @dynlabs/react-native-image-to-webp-example",
    "example:ios": "yarn workspace @dynlabs/react-native-image-to-webp-example ios",
    "example:android": "yarn workspace @dynlabs/react-native-image-to-webp-example android",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "prepare": "bob build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "format": "prettier --write \"**/*.{js,ts,tsx,json,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{js,ts,tsx,json,md}\" --ignore-path .prettierignore",
    "test": "echo \"No tests specified\" && exit 0",
    "build": "bob build"
  },
  "keywords": [
    "react-native",
    "ios",
    "android",
    "webp",
    "image",
    "image-converter",
    "image-compression",
    "webp-converter",
    "convert-to-webp",
    "jpeg-to-webp",
    "png-to-webp",
    "libwebp",
    "turbomodule",
    "new-architecture",
    "native-module",
    "image-optimization",
    "image-resize",
    "exif",
    "kotlin",
    "swift"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dynlabs/react-native-image-to-webp.git"
  },
  "author": "dynlabs",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dynlabs/react-native-image-to-webp/issues"
  },
  "homepage": "https://github.com/dynlabs/react-native-image-to-webp#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^9.35.0",
    "@react-native/babel-preset": "0.83.0",
    "@react-native/eslint-config": "0.84.1",
    "@types/react": "^19.2.0",
    "del-cli": "^6.0.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^2.8.8",
    "react": "19.2.0",
    "react-native": "0.83.0",
    "react-native-builder-bob": "^0.40.17",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "workspaces": [
    "example",
    "website"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "ReactNativeImageToWebpSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.dynlabs.reactnativeimagetowebp"
    }
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "kotlin-objc",
    "tools": [
      "eslint"
    ],
    "version": "0.57.0"
  }
}
